{
  "name": "dadida-starter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env index.ts",
    "build": "tsup",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "backfill": "node --env-file-if-exists=.env dist/backfill.js",
    "mem0:backfill": "node --env-file-if-exists=.env dist/mem0-backfill.js"
  },
  "dependencies": {
    "dadida": "^0.4.0",
    "@openai/agents": "^0.11.0",
    "better-sqlite3": "^11.10.0",
    "discord.js": "^14.16.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
