# ── Required ──────────────────────────────────────────────

# Discord bot token. Create an app at https://discord.com/developers/applications
# → Bot → Reset Token. Remember to enable the "Message Content Intent".
DISCORD_TOKEN=

# OpenAI API key. Used by @openai/agents for all classification, replies, and
# moderation (responder model: gpt-4.1-mini). Read implicitly by the SDK.
OPENAI_API_KEY=

# ── Optional ──────────────────────────────────────────────

# Channel ID the bot listens to. If empty, the bot listens to ALL channels.
GENERAL_CHANNEL_ID=

# Minimum confidence (0–1) for the persona to reply to a message.
# Higher = quieter/more precise, lower = chattier. Default: 0.75
CONFIDENCE_THRESHOLD=0.75

# Moderator escalation (triggered after a user's 4th violation):
# If set, escalation alerts are posted to this dedicated channel.
ESCALATE_CHANNEL_ID=

# Fallback used ONLY when ESCALATE_CHANNEL_ID is empty: mention this
# target (e.g. <@&ADMIN_ROLE_ID>) in the original channel on escalation.
# If both are empty, escalations are logged only.
ESCALATE_MENTION=
