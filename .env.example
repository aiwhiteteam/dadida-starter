# ── Required ──────────────────────────────────────────────

# Discord bot token. Create an app at https://discord.com/developers/applications
# → Bot → Reset Token. Remember to enable the "Message Content Intent".
DISCORD_TOKEN=

# OpenAI API key. Used by @openai/agents for all classification, replies, and
# moderation (responder model: gpt-4.1-mini). Read implicitly by the SDK.
OPENAI_API_KEY=

# ── Optional ──────────────────────────────────────────────

# Channel ID(s) the bot listens to. Comma-separate to listen on several
# channels (e.g. 123,456). If empty, the bot listens to ALL channels.
LISTEN_CHANNEL_IDS=

# Minimum confidence (0–1) for the persona to reply to a message.
# Higher = quieter/more precise, lower = chattier. Default: 0.75
CONFIDENCE_THRESHOLD=0.75
